# Morpho Yield Optimizer Agent — Configuration
# Copy this file to .env and fill in your values

# Chain — 8453 for Base (recommended for testing, low gas), 1 for Ethereum mainnet
# Note: Morpho is NOT deployed on Sepolia or any testnet. Use a real chain
# with a low daily spend cap (see below) to test safely.
CHAIN_ID=8453

# Morpho Vault addresses to monitor
# Find vaults at: https://app.morpho.org/vaults
# Example Base mainnet USDC vaults (verify on-chain before using):
#   Steakhouse High Yield USDC v1.1: 0xBEEFA7B88064FeEF0cEe02AAeBBd95D30df3878F
#   Moonwell Flagship USDC: 0xc1256Ae5FF1cf2719D4937adb3bbCCab2E00A2Ca
#   Steakhouse Prime USDC: 0xBEEFE94c8aD530842bfE7d8B397938fFc1cb83b2
VAULT_1=
VAULT_2=
VAULT_3=

# The vault your funds are currently in (leave empty for first run; the agent
# will reconcile from on-chain state on startup if you have shares somewhere)
CURRENT_VAULT=

# USDC contract address for your chain
# Ethereum: 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# Base:     0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Amount to deposit (in token smallest units — 1 USDC = 1000000)
DEPOSIT_AMOUNT=1000000

# Minimum APY improvement to trigger rebalance (percentage points)
MIN_APY_DELTA=0.5

# Check interval in milliseconds (default: 30 min = 1800000)
CHECK_INTERVAL_MS=1800000

# RPC URL for the target chain
RPC_URL=https://mainnet.base.org

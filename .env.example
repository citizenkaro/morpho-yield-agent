# Morpho Yield Optimizer Agent — Configuration
# Copy this file to .env and fill in your values

# Chain — 11155111 for Sepolia testnet, 1 for Ethereum mainnet, 8453 for Base
CHAIN_ID=11155111

# Morpho Vault addresses to monitor
# Find vaults at: https://app.morpho.org/vaults
# Example Ethereum mainnet vaults:
#   Steakhouse USDC: 0xBEEF01735c132Ada46AA9aA4c54623cAA92A64CB
#   Gauntlet USDC Prime: 0xdd0f28e19C1780eb6396170735D45153D261571d
VAULT_1=
VAULT_2=
VAULT_3=

# The vault your funds are currently in (leave empty for first run)
CURRENT_VAULT=

# USDC contract address for your chain
# Ethereum: 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# Base: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Amount to deposit (in token smallest units — 1 USDC = 1000000)
DEPOSIT_AMOUNT=1000000

# Minimum APY improvement to trigger rebalance (percentage points)
MIN_APY_DELTA=0.5

# Check interval in milliseconds (default: 30 min = 1800000)
CHECK_INTERVAL_MS=1800000

# Optional: custom RPC URL (waap-cli auto-selects if omitted)
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
